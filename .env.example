# Supabase - Claves públicas (seguras para frontend)
NEXT_PUBLIC_SUPABASE_URL=https://tu-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-publishable-anon-key

# Supabase - Clave secreta (solo backend, NUNCA exponer)
SUPABASE_SERVICE_ROLE_KEY=tu-secret-key-larga

# Email SMTP (Gmail recomendado)
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password-de-16-digitos
EMAIL_FROM="BlackyQR <tu-email@gmail.com>"

# Encryption secret (32 bytes base64)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET=

# Cleanup cron secret
CLEANUP_SECRET=

# Admin notifications
ADMIN_EMAIL=n.ibacache.z@gmail.com

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth (opcional)
NEXTAUTH_SECRET=n.ibacache.z@gmail.com

# Public Supabase keys for client-side
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
